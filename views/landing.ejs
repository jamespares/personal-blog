<%- include('partials/header') %>

<div class="simple-landing">
    <!-- Social Links at the Top -->
    <section class="top-social">
        <div class="social-links-row">
            <a href="https://www.linkedin.com/in/james-p-ba7653207/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <span class="sep">/</span>
            <a href="https://x.com/jamespareslfg" target="_blank" rel="noopener noreferrer">X</a>
            <span class="sep">/</span>
            <a href="https://github.com/jamespares" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
    </section>

    <!-- Products Section -->
    <% if (activeProducts.length > 0) { %>
        <section class="simple-section">
            <h2 class="section-title">Products</h2>
            <div class="product-list-minimal">
                <% activeProducts.forEach(function(product) { %>
                    <article class="product-item">
                        <div class="product-header">
                            <h3><a href="<%= product.live_url || '#' %>" target="_blank"><%= product.name %></a></h3>
                            <span class="product-tagline-inline">— <%= product.tagline %></span>
                        </div>
                    </article>
                <% }); %>
            </div>
        </section>
    <% } %>

    <!-- Blog Section -->
    <% if (recentPosts.length > 0) { %>
        <section class="simple-section">
            <h2 class="section-title">Blog</h2>
            <div class="post-list-minimal">
                <% recentPosts.forEach(function(post) { %>
                    <article class="post-item">
                        <time class="post-date-minimal"><%= new Date(post.created_at).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' }) %></time>
                        <a href="/post/<%= post.slug %>" class="post-link-minimal"><%= post.title %></a>
                        <span class="post-topic-minimal">in <%= formatTopic(post.topic) %></span>
                    </article>
                <% }); %>
            </div>
        </section>
    <% } %>
</div>

<%- include('partials/footer') %>
