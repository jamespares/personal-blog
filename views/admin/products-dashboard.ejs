<%- include('../partials/header', { pageTitle: 'Manage Products' }) %>

<section class="admin-dashboard">
    <div class="admin-header">
        <h1>Products</h1>
        <div class="admin-actions">
            <a href="/admin/products/new" class="btn">+ New Product</a>
            <a href="/admin" class="btn btn-ghost">Manage Posts</a>
            <form action="/admin/logout" method="POST" style="display:inline">
                <button type="submit" class="btn btn-ghost">Log Out</button>
            </form>
        </div>
    </div>

    <% if (products.length === 0) { %>
        <div class="empty-state">
            <p>No products yet. Add your first one!</p>
        </div>
    <% } else { %>
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Price</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(function(product) { %>
                        <tr>
                            <td>
                                <a href="/products/<%= product.slug %>" target="_blank">
                                    <%= product.name %>
                                </a>
                            </td>
                            <td>
                                <span class="status-badge <%= product.published ? 'published' : 'draft' %>">
                                    <%= product.published ? (product.status === 'coming_soon' ? 'Coming Soon' : 'Published') : 'Draft' %>
                                </span>
                            </td>
                            <td><%= product.price %></td>
                            <td>
                                <%= new Date(product.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                            </td>
                            <td class="actions-cell">
                                <a href="/admin/products/edit/<%= product.id %>" class="btn btn-sm">Edit</a>
                                <form action="/admin/products/delete/<%= product.id %>" method="POST" style="display:inline"
                                    onsubmit="return confirm('Delete this product?')">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
